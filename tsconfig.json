{
  "compilerOptions": {
    "module": "NodeNext",
    "target": "ES2022",
    "rootDir": "./src",
    "outDir": "out",
    "lib": ["ES2022"],
    "sourceMap": true,
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["mocha"],
    "typeRoots": ["./node_modules/@types"],
    "allowJs": true,
    "checkJs": false,
    "strict": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedParameters": true
  }
}
